{
  "environment": "production",
  "rate_limit": {
    "api_max_requests": 100,
    "api_window_seconds": 60,
    "upload_max_requests": 5,
    "upload_window_seconds": 60
  },
  "cache": {
    "json_ttl_seconds": 60,
    "config_ttl_seconds": 300,
    "static_ttl_seconds": 3600
  },
  "alerts": {
    "cpu_percent_threshold": 85,
    "memory_percent_threshold": 85,
    "disk_percent_threshold": 90
  },
  "logging": {
    "level": "WARNING",
    "max_file_size_mb": 50,
    "backup_count": 5
  },
  "server": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": false,
    "threaded": true
  }
}