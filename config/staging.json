{
  "environment": "staging",
  "rate_limit": {
    "api_max_requests": 200,
    "api_window_seconds": 60,
    "upload_max_requests": 10,
    "upload_window_seconds": 60
  },
  "cache": {
    "json_ttl_seconds": 30,
    "config_ttl_seconds": 120,
    "static_ttl_seconds": 1800
  },
  "alerts": {
    "cpu_percent_threshold": 90,
    "memory_percent_threshold": 90,
    "disk_percent_threshold": 95
  },
  "logging": {
    "level": "DEBUG",
    "max_file_size_mb": 100,
    "backup_count": 3
  },
  "server": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": true,
    "threaded": true
  }
}